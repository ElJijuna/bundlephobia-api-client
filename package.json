{
  "name": "bundlephobia-api-client",
  "version": "0.0.1",
  "type": "module",
  "description": "TypeScript client for the Bundlephobia public API",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "docs": "typedoc",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "biome check --write .",
    "format:check": "biome check .",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:client": "npm run build && node test-client/test.js"
  },
  "keywords": [
    "bundlephobia",
    "bundle-size",
    "api-client",
    "rest",
    "typescript"
  ],
  "license": "MIT",
  "author": "pilmee <pilmee@gmail.com> (https://github.com/ElJijuna)",
  "homepage": "https://eljijuna.github.io/bundlephobia-api-client",
  "bugs": {
    "url": "https://github.com/ElJijuna/bundlephobia-api-client/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ElJijuna/bundlephobia-api-client.git"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/jest": "^29.5.14",
    "eslint": "^9.39.4",
    "jest": "^29.7.0",
    "semantic-release": "^24.2.3",
    "super-configs": "^1.15.0",
    "ts-jest": "^29.3.0",
    "ts-node": "^10.9.2",
    "tsup": "^8.4.0",
    "typedoc": "^0.28.18",
    "typescript": "^5.8.3"
  }
}
